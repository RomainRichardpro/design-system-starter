{
  "name": "design-system-starter",
  "private": true,
  "version": "0.0.0",
  "description": "Template monorepo pour industrialiser un Design System",
  "scripts": {
    "dev": "turbo run dev --filter=@starter/storybook",
    "build": "turbo run build",
